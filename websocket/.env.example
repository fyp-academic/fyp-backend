# Socket.io Server Configuration
SOCKET_PORT=3001

# Laravel API Configuration
LARAVEL_API_URL=https://api.codagenz.com/api/v1
ADMIN_TOKEN=your-secure-admin-token-for-monitoring

# Frontend URLs (comma-separated for CORS)
FRONTEND_URLS=https://apesudom.codagenz.com,https://apesguide.codagenz.com

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Logging
LOG_LEVEL=info
