{
  "name": "lms-jitsi-websocket",
  "version": "1.0.0",
  "description": "Socket.io server for Jitsi video conferencing integration",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start server.js --name lms-websocket",
    "pm2:stop": "pm2 stop lms-websocket",
    "pm2:restart": "pm2 restart lms-websocket"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
